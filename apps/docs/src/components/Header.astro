---
/**
 * Custom Header override that adds a global framework selector (JS / React).
 */
import DefaultHeader from "@astrojs/starlight/components/Header.astro"
---

<div class="pm-header-wrap">
  <DefaultHeader {...Astro.props}><slot /></DefaultHeader>
  <div class="pm-header-fw-selector" id="pm-fw-selector">
    <button data-framework="js" aria-label="Switch to JavaScript docs">JS</button>
    <button data-framework="react" aria-label="Switch to React docs">React</button>
  </div>
</div>

<script>
  function setupHeaderFwSelector() {
    const selector = document.getElementById("pm-fw-selector")
    if (!selector) return

    const stored = localStorage.getItem("pm-framework") || "react"
    const buttons = selector.querySelectorAll("button")

    // Highlight active
    buttons.forEach((btn) => {
      const fw = btn.getAttribute("data-framework")!
      btn.classList.toggle("active", fw === stored)
    })

    // Click handler
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const framework = btn.getAttribute("data-framework")!
        localStorage.setItem("pm-framework", framework)

        // Update active states
        buttons.forEach((b) => {
          b.classList.toggle("active", b.getAttribute("data-framework") === framework)
        })

        // Navigate if on a component page
        const path = window.location.pathname
        if (path.includes("-js/") || path.includes("-react/")) {
          let newPath
          if (framework === "js") {
            newPath = path.replace(/-react\//, "-js/")
          } else {
            newPath = path.replace(/-js\//, "-react/")
          }
          if (newPath !== path) {
            window.location.href = newPath
          }
        }

        // Rewrite sidebar links
        rewriteSidebarLinks(framework)
      })
    })

    // Rewrite sidebar links on load
    rewriteSidebarLinks(stored)
  }

  function rewriteSidebarLinks(framework: string) {
    const links = document.querySelectorAll("nav.sidebar a")
    links.forEach((link) => {
      const href = link.getAttribute("href")
      if (!href) return
      if (href.includes("-react/") || href.includes("-js/")) {
        let newHref
        if (framework === "js") {
          newHref = href.replace(/-react\//, "-js/")
        } else {
          newHref = href.replace(/-js\//, "-react/")
        }
        if (newHref !== href) {
          link.setAttribute("href", newHref)
        }
      }
    })
  }

  setupHeaderFwSelector()
  document.addEventListener("astro:page-load", setupHeaderFwSelector)
</script>

<style>
  .pm-header-wrap {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .pm-header-wrap > :first-child {
    flex: 1;
    min-width: 0;
  }
  .pm-header-fw-selector {
    display: inline-flex;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    overflow: hidden;
    flex-shrink: 0;
  }
  .pm-header-fw-selector button {
    padding: 0.2rem 0.6rem;
    border: none;
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    transition: background 0.15s, color 0.15s;
    line-height: 1.4;
  }
  .pm-header-fw-selector button:hover {
    background: var(--sl-color-gray-6);
  }
  .pm-header-fw-selector button.active {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-text-accent);
  }
  @media (max-width: 49.99rem) {
    .pm-header-fw-selector {
      display: none;
    }
  }
</style>
